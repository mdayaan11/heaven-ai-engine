# ─────────────────────────────────────────────
# HEAVEN AI ENGINE — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# LLM
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Sandbox (https://e2b.dev)
E2B_API_KEY=e2b_your-key-here

# GitHub (Personal Access Token with repo scope)
GITHUB_TOKEN=ghp_your-token-here
GITHUB_USERNAME=your-github-username

# Vercel (https://vercel.com/account/tokens)
VERCEL_TOKEN=your-vercel-token-here
VERCEL_TEAM_ID=                        # Optional: leave blank for personal

# Render (https://render.com)
RENDER_API_KEY=rnd_your-key-here

# Redis (local: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development                # development | production

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://heavenaii.netlify.app
